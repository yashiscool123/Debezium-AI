#!/bin/bash
# ===============================================================
# Debezium AI — Unified CLI
# ===============================================================
# Usage: ./debezium-ai <command> [options]
#
# Commands:
#   build [v3|v4|all]   Build project modules (default: all)
#   run [v3|v4]         Run in Quarkus dev mode (default: v4)
#   setup               Run interactive setup wizard
#   docker [profile]    Run Docker Compose (dev|full|streaming|monitoring)
#   help                Show this help message
# ===============================================================

set -e

VERSION="4.1.0"
ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
MW="$ROOT_DIR/mvnw"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

info()  { echo -e "${BLUE}[debezium-ai]${NC} $1"; }
ok()    { echo -e "${GREEN}[✓]${NC} $1"; }
warn()  { echo -e "${YELLOW}[!]${NC} $1"; }
err()   { echo -e "${RED}[✗]${NC} $1" >&2; }

usage() {
    cat <<EOF
Debezium AI v${VERSION} — Unified CLI

Usage: ./debezium-ai <command> [options]

Commands:
  build [v3|v4|all]   Build project modules (default: all)
  run [v3|v4]         Run in Quarkus dev mode (default: v4)
  setup               Run interactive setup wizard
  docker [profile]    Run Docker Compose (dev|full|streaming|monitoring)
  help                Show this help message

Examples:
  ./debezium-ai build          Build everything (Debezium Core + v3 + v4)
  ./debezium-ai build v4       Build only v4 pipeline generator
  ./debezium-ai run v4         Start v4 in dev mode
  ./debezium-ai docker dev     Start lightweight dev stack
  ./debezium-ai setup          Launch interactive configuration wizard
EOF
}

check_mvnw() {
    if [ ! -f "$MW" ]; then
        err "Maven wrapper not found at $MW"
        exit 1
    fi
}

cmd_build() {
    local target="${1:-all}"
    check_mvnw
    case "$target" in
        v3)
            info "Building v3 Pipeline Generator..."
            (cd "$ROOT_DIR/debezium-pipeline-generator" && $MW clean install -Dquick "$@")
            ok "v3 build complete"
            ;;
        v4)
            info "Building v4 Pipeline Generator..."
            (cd "$ROOT_DIR/debezium-pipeline-v4" && $MW clean install -Dquick "$@")
            ok "v4 build complete"
            ;;
        all|"")
            info "Building entire project (Debezium Core + v3 + v4)..."
            $MW clean install -Dquick -DskipITs "$@"
            ok "Full build complete"
            ;;
        *)
            err "Unknown target: $target. Use v3, v4, or all."
            exit 1
            ;;
    esac
}

cmd_run() {
    local target="${1:-v4}"
    check_mvnw
    case "$target" in
        v3)
            info "Starting v3 in dev mode on http://localhost:8080/api/v1..."
            (cd "$ROOT_DIR/debezium-pipeline-generator" && $MW quarkus:dev)
            ;;
        v4)
            info "Starting v4 in dev mode on http://localhost:8080/v4..."
            (cd "$ROOT_DIR/debezium-pipeline-v4" && $MW quarkus:dev)
            ;;
        *)
            err "Unknown target: $target. Use v3 or v4."
            exit 1
            ;;
    esac
}

cmd_setup() {
    local installer="$ROOT_DIR/debezium-pipeline-v4/installer/setup.sh"
    if [ ! -f "$installer" ]; then
        err "Installer not found at $installer"
        exit 1
    fi
    info "Launching interactive setup wizard..."
    bash "$installer"
}

cmd_docker() {
    local profile="${1:-dev}"
    local compose="$ROOT_DIR/debezium-pipeline-v4/installer/docker-compose.yml"
    if [ ! -f "$compose" ]; then
        err "Docker Compose file not found at $compose"
        exit 1
    fi
    case "$profile" in
        dev|full|streaming|monitoring)
            info "Starting Docker Compose with profile: $profile"
            (cd "$(dirname "$compose")" && docker compose --profile "$profile" up -d)
            ok "Docker Compose started (profile: $profile)"
            info "App: http://localhost:8080/v4"
            info "Health: http://localhost:8080/q/health"
            ;;
        down)
            info "Stopping Docker Compose..."
            (cd "$(dirname "$compose")" && docker compose down)
            ok "Docker Compose stopped"
            ;;
        logs)
            (cd "$(dirname "$compose")" && docker compose logs -f)
            ;;
        *)
            err "Unknown profile: $profile. Use dev, full, streaming, monitoring, down, or logs."
            exit 1
            ;;
    esac
}

# --- Main ---
case "${1:-help}" in
    build) shift; cmd_build "$@" ;;
    run)   shift; cmd_run "$@" ;;
    setup) cmd_setup ;;
    docker) shift; cmd_docker "$@" ;;
    help|--help|-h) usage ;;
    *)
        err "Unknown command: $1"
        usage
        exit 1
        ;;
esac