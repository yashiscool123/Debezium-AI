# ===============================================================
# Debezium AI — Environment Variables
# ===============================================================
# Copy this file to .env and adjust values for your environment.
# ===============================================================

# Application
PORT=8080
API_KEY=change-this-to-a-secure-random-key

# Authentication
AUTH_TYPE=local
# For OIDC/SSO:
# AUTH_TYPE=oidc
# OIDC_ISSUER=https://your-keycloak/auth/realms/debezium
# OIDC_CLIENT_ID=debezium-ai
# OIDC_CLIENT_SECRET=your-client-secret

# Storage
STORAGE_TYPE=memory
DB_PASSWORD=debezium

# For PostgreSQL:
# STORAGE_TYPE=postgresql
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=debezium_ai
# DB_USER=debezium

# For MongoDB:
# STORAGE_TYPE=mongodb
# MONGO_URI=mongodb://debezium:password@mongodb:27017/debezium_ai

# AI/ML
AI_EMBEDDINGS_PROVIDER=minilm
AI_LLM_PROVIDER=none
# For Ollama:
# AI_LLM_PROVIDER=ollama
# OLLAMA_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.1
# For OpenAI:
# AI_LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4

# Monitoring
GRAFANA_PASSWORD=admin

# Deployment
DEPLOYMENT_TARGET=docker
NAMESPACE=debezium-ai
